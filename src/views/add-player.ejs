<%- include('partials/header') %>

<h2 class="title">Add Player</h2>

<form class="form-card" action="/players/new" method="POST">

    <div class="form-group">
        <label for="nickname">Player's nickname:</label>
        <input type="text" id="nickname" name="nickname" required>
    </div>

    <div class="form-row">
        <div class="form-group">
            <label for="first_name">Player's first name:</label>
            <input type="text" id="first_name" name="first_name">
        </div>

        <div class="form-group">
            <label for="last_name">Player's last name:</label>
            <input type="text" id="last_name" name="last_name">
        </div>
    </div>

    <div class="form-group">
        <label for="picture">Player's picture:</label>
        <input type="text" id="picture" name="picture" placeholder="https://...">
    </div>

    <div class="form-group">
        <label for="nationality">Player's nationality:</label>
        <input type="text" id="nationality" name="nationality">
    </div>

    <div class="form-group">
        <label for="date_of_birth">Player's date of birth:</label>
        <input type="text" id="date_of_birth" name="date_of_birth" placeholder="YYYY-MM-DD">
    </div>

    <div class="form-group">
        <label for="role">Player's role:</label>
        <input type="text" id="role" name="role" required>
    </div>

    <div class="form-group">
        <label for="team">Player's team:</label>
        <input type="text" id="team" name="team" required>
    </div>

    <div class="form-actions">
        <button type="submit">Save Player</button>
    </div>
</form>

<h2 class="title">Remove Player</h2>

<form class="form-card" action="/players/remove" method="POST">

    <div class="form-group">
        <label for="nickname">Player's nickname:</label>
        <input type="text" id="remove-nickname" name="nickname" required>
    </div>

    <div class="form-actions">
        <button type="submit">Remove Player</button>
    </div>  
</form>

<%- include('partials/footer') %>