<%- include('partials/header') %>

<h2 class="title">Add Team</h2>

<form class="form-card" method="POST" action="/teams/new" >

    <div class="form-group">
        <label for="title">Team's title</label>
        <input type="text" id="title" name="title" required>
    </div>

    <div class="form-group">
        <label for="logo">Team's logo</label>
        <input type="text" id="logo" name="logo" placeholder="https://...">
    </div>

    <div class="form-group">
        <label for="region">Region</label>
        <input type="text" id="region" name="region">
    </div>

    <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description"></textarea>
    </div>

    <div class="form-actions">
        <button type="submit">Save Team</button>
    </div>
</form>

<h2 class="title">Remove Team</h2>

<form class="form-card" action="/teams/remove" method="POST">

    <div class="form-group">
        <label for="title">Team's title:</label>
        <input type="text" id="title" name="title" required>
    </div>

    <div class="form-actions">
        <button type="submit">Remove Team</button>
    </div>

</form>


<%- include('partials/footer') %>